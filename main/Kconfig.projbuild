menu "Board Selection"

    choice BOARD_TARGET
        prompt "Target board"
        default BOARD_M5STACK_BASIC_V27

        config BOARD_M5STACK_BASIC_V27
            bool "M5Stack Basic v2.7 (ESP32)"

        config BOARD_WAVESHARE_S3_LCD19
            bool "Waveshare ESP32-S3-LCD-1.9 (ESP32-S3)"
    endchoice

endmenu

menu "GPS Configuration"

    config GPS_UART_NUM
        int "UART port number for GPS"
        default 2 if BOARD_M5STACK_BASIC_V27
        default 1 if BOARD_WAVESHARE_S3_LCD19
        range 0 2
        help
            UART port number used for GPS communication.

    config GPS_UART_BAUD_RATE
        int "GPS UART baud rate"
        default 115200 if BOARD_M5STACK_BASIC_V27
        default 9600   if BOARD_WAVESHARE_S3_LCD19
        help
            Baud rate for GPS UART communication.

    config GPS_UART_TX_PIN
        int "GPS UART TX GPIO pin"
        default 17 if BOARD_M5STACK_BASIC_V27
        default 18 if BOARD_WAVESHARE_S3_LCD19
        range 0 48
        help
            GPIO number for GPS UART TX (ESP to GPS).

    config GPS_UART_RX_PIN
        int "GPS UART RX GPIO pin"
        default 16 if BOARD_M5STACK_BASIC_V27
        default 17 if BOARD_WAVESHARE_S3_LCD19
        range 0 48
        help
            GPIO number for GPS UART RX (GPS to ESP).

endmenu
